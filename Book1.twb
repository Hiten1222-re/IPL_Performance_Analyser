      </column>
      <column caption='Top_teams_batters' datatype='string' name='[Calculation_0945312750579712]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [batting_team]=&apos;Chennai Super Kings&apos;&#13;&#10;OR [batting_team]=&apos;Kolkata Knight Riders&apos;&#13;&#10;OR [batting_team]=&apos;Mumbai Indians&apos;&#13;&#10;THEN [batter]&#13;&#10;END' />
      </column>
      <column caption='Phase' datatype='string' name='[Calculation_0945312760311810]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [over] &gt; 6&#13;&#10;THEN &quot;Powerplay&quot;&#13;&#10;ELSEIF [over] &gt; 16&#13;&#10;THEN &quot;Death&quot;&#13;&#10;ELSE &quot;Middle&quot;&#13;&#10;END' />
      </column>
