    <worksheet name='Sheet 2'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Top 3 teams with their top run-scorers</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='deliveries (deliveries)' name='federated.1fdr29w0zqsuk7166v6l403p14n4' />
          </datasources>
          <datasource-dependencies datasource='federated.1fdr29w0zqsuk7166v6l403p14n4'>
            <column caption='Top_teams_batters' datatype='string' name='[Calculation_0945312750579712]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [batting_team]=&apos;Chennai Super Kings&apos;&#13;&#10;OR [batting_team]=&apos;Kolkata Knight Riders&apos;&#13;&#10;OR [batting_team]=&apos;Mumbai Indians&apos;&#13;&#10;THEN [batter]&#13;&#10;END' />
            </column>
            <column caption='Batter' datatype='string' name='[batter]' role='dimension' type='nominal' />
            <column caption='Batting Team' datatype='string' name='[batting_team]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0945312750579712]' derivation='None' name='[none:Calculation_0945312750579712:nk]' pivot='key' type='nominal' />
            <column-instance column='[batting_team]' derivation='None' name='[none:batting_team:nk]' pivot='key' type='nominal' />
            <column-instance column='[total_runs]' derivation='Sum' name='[sum:total_runs:qk]' pivot='key' type='quantitative' />
            <column caption='Total Runs' datatype='integer' name='[total_runs]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1fdr29w0zqsuk7166v6l403p14n4].[none:Calculation_0945312750579712:nk]'>
            <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([total_runs])' function='order' user:ui-marker='order'>
