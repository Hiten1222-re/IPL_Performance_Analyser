              <calculation class='tableau' formula='IF [batting_team]=&apos;Chennai Super Kings&apos;&#13;&#10;OR [batting_team]=&apos;Kolkata Knight Riders&apos;&#13;&#10;OR [batting_team]=&apos;Mumbai Indians&apos;&#13;&#10;THEN [batter]&#13;&#10;END' />
